# rust-quant-bot — exemple de configuration. COPIER en `.env` (jamais commité, cf. .gitignore).

# ── Général ──────────────────────────────────────────────────────────────────
DRY_RUN=true
PORT=8768
RUST_LOG=info
START_CASH=200

# ── Risque / circuit breaker ─────────────────────────────────────────────────
MAX_DRAWDOWN=20          # coupe l'exécution si equity ≤ START_CASH - MAX_DRAWDOWN

# ── LIVE (passage au réel) ───────────────────────────────────────────────────
# VERROU MATÉRIEL : laisser `false` tant que la signature EIP-712 n'est pas vérifiée.
# Même à `true`, aucun ordre ne part tant que sign_order_eip712 n'est pas implémenté/validé.
LIVE_ARMED=false

# Credentials L2 — générés EN AMONT (flow L1 hors bot), à NE JAMAIS committer.
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=
POLY_FUNDER_ADDRESS=      # adresse proxy/funder Polymarket (détient les USDC) — visible dans l'UI compte
POLY_SIGNER_ADDRESS=      # adresse EOA liée à l'API key — auth L2 (POLY_ADDRESS) ; ≠ funder si type 1 ou 3
POLY_PRIVATE_KEY=         # clé privée de l'EOA signataire — SECRET ABSOLU
# 0=EOA (MetaMask) | 1=Google/email Magic (proxy) | 2=Gnosis Safe | 3=deposit wallet API (POLY_1271)
POLY_SIG_TYPE=1           # Google/email → 1 ; nouveau flux API deposit wallet → 3

# Pré-flight auth L2 (sans lancer le bot) :
#   cargo run --release -- poly-check
