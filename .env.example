# rust-quant-bot — exemple de configuration. COPIER en `.env` (jamais commité, cf. .gitignore).

# ── Général ──────────────────────────────────────────────────────────────────
DRY_RUN=true
PORT=8768
RUST_LOG=info
START_CASH=200

# ── Risque / circuit breaker ─────────────────────────────────────────────────
MAX_DRAWDOWN=20          # coupe l'exécution si equity ≤ START_CASH - MAX_DRAWDOWN

# ── LIVE (passage au réel) ───────────────────────────────────────────────────
# VERROU MATÉRIEL : laisser `false` tant que la signature n'est pas vérifiée.
LIVE_ARMED=false
# Taille minimale forcée (ignore Kelly) — AGRESSIF, ~13%/trade sur petite bankroll.
# Uniquement pour valider la plomberie d'un 1er ordre réel ; remettre `false` ensuite.
LIVE_FORCE_MIN_SIZE=false

# Credentials L2 — générés via `cargo run --features live -- poly derive-creds` (local).
# Ops AWS : `cargo run --release --features live -- poly verify` (preflight, sans Python).
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=
POLY_PRIVATE_KEY=         # clé MetaMask exportée — SECRET ABSOLU
POLY_FUNDER_ADDRESS=      # sig_type 0 : EOA MetaMask | sig_type 2 : proxy | sig_type 3 : deposit wallet
POLY_SIGNER_ADDRESS=      # sig_type 0 : optionnel (= funder) | sig_type 2/3 : EOA MetaMask owner
POLY_SIG_TYPE=2            # 0=EOA | 2=Gnosis Safe proxy | 3=deposit wallet POLY_1271
